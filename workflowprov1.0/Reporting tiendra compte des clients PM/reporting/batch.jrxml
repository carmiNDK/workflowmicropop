<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="contrat" language="groovy" pageWidth="1300" pageHeight="2500" columnWidth="1260" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="libellegrp" class="java.lang.String"/>
	<parameter name="cycledossier" class="java.lang.String"/>
	<queryString>
		<![CDATA[select m.NumClientMembreCbs,m.NomMembreGroupe,m.PostNomMembreGroupe,m.PreNomMembreGroupe,grp.NumeroGroupeCBS,grp.NomGroupe,F.RemboursementGL,u.NomsUser
from membregroupe as m inner join groupegl as grp on grp.Id=m.IdGroupeLisanga
inner join dossiercreditgl as doss on doss.IdMembreGL=m.IdClientMembre
inner join informationfinanciereclientgl as F on F.IdDossierClientGL=doss.NumDossierGL
inner join user as u on u.Iduser=grp.PromoteurGroupe
where grp.NomGroupe=$P{libellegrp} and doss.CycleGL=$P{cycledossier}
order by m.NomMembreGroupe asc;]]>
	</queryString>
	<field name="NumClientMembreCbs" class="java.lang.Integer"/>
	<field name="NomMembreGroupe" class="java.lang.String"/>
	<field name="PostNomMembreGroupe" class="java.lang.String"/>
	<field name="PreNomMembreGroupe" class="java.lang.String"/>
	<field name="NumeroGroupeCBS" class="java.lang.Integer"/>
	<field name="NomGroupe" class="java.lang.String"/>
	<field name="RemboursementGL" class="java.lang.Double"/>
	<field name="NomsUser" class="java.lang.String"/>
	<variable name="RemboursementGL_1" class="java.lang.Double" calculation="Sum">
