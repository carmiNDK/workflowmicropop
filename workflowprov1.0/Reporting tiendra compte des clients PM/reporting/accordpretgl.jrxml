<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="contrat" language="groovy" pageWidth="1300" pageHeight="2500" columnWidth="1260" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="15"/>
	<property name="ireport.y" value="585"/>
	<parameter name="libellegrp" class="java.lang.String"/>
	<parameter name="cycledossier" class="java.lang.String"/>
	<queryString>
		<![CDATA[select m.NumClientMembreCbs,m.NomMembreGroupe,m.PostNomMembreGroupe,m.PreNomMembreGroupe,grp.NumeroGroupeCBS,grp.NomGroupe,u.NomsUser,grp.ChefAgence,m.CategorieMembreGroupe,count(m.IdClientMembre),sum(doss.PretAccorder),sum(F.TotalRemboursementGL),sum(F.RemboursementGL)
from membregroupe as m inner join groupegl as grp on grp.Id=m.IdGroupeLisanga
inner join dossiercreditgl as doss on doss.IdMembreGL=m.IdClientMembre
inner join informationfinanciereclientgl as F on F.IdDossierClientGL=doss.NumDossierGL
inner join user as u on u.Iduser=grp.PromoteurGroupe
where grp.NomGroupe=$P{libellegrp} and doss.CycleGL=$P{cycledossier} and (m.priority=1 or m.priority=2 or m.priority=3 or m.priority=4 or m.priority=5)
group by m.NumClientMembreCbs,m.NomMembreGroupe,m.PostNomMembreGroupe,m.PreNomMembreGroupe,grp.NumeroGroupeCBS,grp.NomGroupe,u.NomsUser,grp.ChefAgence
order by m.priority asc;]]>
	</queryString>
	<field name="NumClientMembreCbs" class="java.lang.Integer"/>
	<field name="NomMembreGroupe" class="java.lang.String"/>
	<field name="PostNomMembreGroupe" class="java.lang.String"/>
	<field name="PreNomMembreGroupe" class="java.lang.String"/>
	<field name="NumeroGroupeCBS" class="java.lang.Integer"/>
	<field name="NomGroupe" class="java.lang.String"/>
	<field name="NomsUser" class="java.lang.String"/>
	<field name="ChefAgence" class="java.lang.String"/>
	<field name="CategorieMembreGroupe" class="java.lang.String"/>
	<field name="count(m.IdClientMembre)" class="java.lang.Long"/>
	<field name="sum(doss.PretAccorder)" class="java.lang.Double"/>
	<field name="sum(F.TotalRemboursementGL)" class="java.lang.Double"/>
	<field name="sum(F.RemboursementGL)" class="java.lang.Double"/>
	<variable name="sum(doss.PretAccorder)_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{sum(doss.PretAccorder)}]]></variableExpression>
	</variable>
	<variable name="sum(F.TotalRemboursementGL)_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{sum(F.TotalRemboursementGL)}]]></variableExpression>
	</variable>
	<variable name="sum(F.RemboursementGL)_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{sum(F.RemboursementGL)}]]></variableExpression>
	</variable>
	<variable name="count(m.IdClientMembre)_1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{count(m.IdClientMembre)}]]></variableExpression>
	</variable>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="2198" splitType="Stretch">
			<image hAlign="Center" vAlign="Middle">
				<reportElement x="0" y="0" width="118" height="97"/>
				<imageExpression class="java.lang.String"><![CDATA["photos.jpg"]]></imageExpression>
			</image>
			<rectangle>
				<reportElement x="268" y="25" width="727" height="72"/>
				<graphicElement>
					<pen lineStyle="Dashed"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="417" y="46" width="448" height="28"/>
