				</textElement>
				<text><![CDATA[Accord de Prêt]]></text>
			</staticText>
			<textField pattern="dd/MM/yyyy">
				<reportElement x="227" y="230" width="186" height="37"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="15" isBold="true"/>
