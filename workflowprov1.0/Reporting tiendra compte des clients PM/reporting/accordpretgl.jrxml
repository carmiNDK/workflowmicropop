					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.Double"><![CDATA[$V{sum(F.RemboursementGL)_1}]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Report">
				<reportElement x="380" y="549" width="226" height="37"/>
