	<property name="ireport.y" value="0"/>
	<parameter name="numgrp" class="java.lang.String"/>
	<queryString>
		<![CDATA[select CONCAT_WS(' ', cli.NomMembreGroupe,cli.PostNomMembreGroupe,cli.PreNomMembreGroupe) AS nom_complet,
cli.NumClientMembreCbs,
cli.NumClientMembreCbs,cli.DateNaissanceMembreGroupe,dossGL.NumDossierGL,dossGL.DateDossierGL,dossGL.EtatDossierGL,dossGL.DepotAvue,dossGL.CautionFinanciere,dossGL.TotalEpargne,dossGL.DernierPret,dossGL.PretSollicite,dossGL.PretAccorder,dossGL.FraisDossierTVA,dossGL.AssuranceGL,dossGL.SmsGl,dossGL.CarnetLivre,dossGL.TotalFraisGL,dossGL.CycleGL,dossGL.CategorisationM,gp.NumeroGroupeCBS,gp.NomGroupe from dossiercreditgl as dossGL inner join membregroupe as cli on cli.IdClientMembre=dossGL.IdMembreGL inner join groupegl as gp on gp.Id=cli.IdGroupeLisanga
where gp.NbrCycleGroupe=dossGL.CycleGL and gp.Id=$P{numgrp}
and gp.EtatGroupGL=dossGL.EtatDossierGL]]>
	</queryString>
