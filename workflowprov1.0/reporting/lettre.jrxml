				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font size="15" isBold="true"/>
				</textElement>
				<text><![CDATA[- Tous produits jugés dangereux pour la santé ou portant atteinte aux bonnes mœurs ]]></text>
