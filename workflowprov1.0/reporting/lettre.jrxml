				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font size="15" isBold="true"/>
				</textElement>
				<text><![CDATA[- Les explosifs, les mines anti-personnelles (mercure rouge, coltan, uranium, ivoire …)]]></text>
			</staticText>
