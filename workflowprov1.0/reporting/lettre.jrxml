				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font size="15" isBold="true"/>
				</textElement>
				<text><![CDATA[- Les changeurs de monnaie de rue (cambiste), les banques Lambert et les frappeurs de monnaie]]></text>
			</staticText>
			<staticText>
				<reportElement x="104" y="964" width="989" height="33"/>
