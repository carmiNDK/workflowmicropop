				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font size="15" isBold="true"/>
				</textElement>
				<text><![CDATA[- Toute activité en rapport d'une manière ou d'une autre au blanchiment des capitaux et au financement du  terrorisme]]></text>
